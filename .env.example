NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Email delivery via Resend (https://resend.com)
# Without this, invite emails are skipped — links must be shared manually.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
FROM_EMAIL=Eunoia AI OS <noreply@yourdomain.com>

# Sentry error tracking (https://sentry.io)
# NEXT_PUBLIC_SENTRY_DSN is included in the client bundle — Sentry DSNs are safe to expose.
# SENTRY_AUTH_TOKEN is needed only for source map upload at CI build time.
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=eunoia-ai-os-platform
SENTRY_AUTH_TOKEN=sntrys_YOUR_AUTH_TOKEN

# Prometheus metrics endpoint — leave unset to allow open access (dev only)
# In production, set this to a strong random token and configure in Prometheus:
#   Authorization: Bearer <METRICS_TOKEN>
METRICS_TOKEN=change-me-in-production

# Health provider feature flags (default: enabled — set to false to disable)
# Disable individual providers without removing them from the registry.
ENABLE_STORAGE_HEALTH=true
ENABLE_OPENAI_HEALTH=true
ENABLE_EMAIL_HEALTH=true
ENABLE_CACHE_HEALTH=true
ENABLE_QUEUE_HEALTH=true
