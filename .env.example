# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# NEVER add SUPABASE_SERVICE_ROLE_KEY to Vercel — scripts only, local .env.local only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── Core application ─────────────────────────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# Must match your Vercel deployment URL exactly (no trailing slash)
# Used for: password reset links, invite links, Stripe success/cancel URLs
NEXT_PUBLIC_APP_URL=https://eunoia-ai-os-platform.vercel.app

# ─── Email delivery (Resend) ──────────────────────────────────────────────────
# Without RESEND_API_KEY, invite emails are silently skipped.
# FROM_EMAIL domain must be verified in your Resend account.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
FROM_EMAIL=Eunoia AI OS <noreply@yourdomain.com>
# Where to receive demo request notifications from the landing page
DEMO_REQUEST_EMAIL=hello@yourdomain.com

# ─── Stripe billing ───────────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
# Get from: Stripe Dashboard → Products → (each product) → Prices → copy price ID
STRIPE_STARTER_MONTHLY_PRICE_ID=price_YOUR_STARTER_MONTHLY
STRIPE_STARTER_ANNUAL_PRICE_ID=price_YOUR_STARTER_ANNUAL
STRIPE_PRO_MONTHLY_PRICE_ID=price_YOUR_PRO_MONTHLY
STRIPE_PRO_ANNUAL_PRICE_ID=price_YOUR_PRO_ANNUAL

# ─── Sentry error tracking ────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN is safe to expose (it's a public key).
# SENTRY_AUTH_TOKEN is CI-only for source map upload — never in Vercel.
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=eunoia-ai-os-platform
SENTRY_AUTH_TOKEN=sntrys_YOUR_AUTH_TOKEN

# ─── Observability ────────────────────────────────────────────────────────────
# METRICS_TOKEN: required in production — open without it
# Generate: openssl rand -base64 32
METRICS_TOKEN=change-me-in-production

# ─── Health provider feature flags ────────────────────────────────────────────
# Set to false to disable individual health providers.
ENABLE_STORAGE_HEALTH=true
ENABLE_OPENAI_HEALTH=true
ENABLE_EMAIL_HEALTH=true
ENABLE_CACHE_HEALTH=true
ENABLE_QUEUE_HEALTH=true
