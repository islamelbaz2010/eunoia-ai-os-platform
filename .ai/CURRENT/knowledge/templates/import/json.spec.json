{
  "schema_version": "1.0.0",
  "format_name": "JSON",
  "format_id": "json",
  "mime_type": "application/json",
  "description": "Import specification for JSON documents. Supports single objects and JSON arrays.",
  "version": "1.0.0",
  "last_updated": "2026-07-13T00:00:00.000Z",
  "supported_features": {
    "nested_objects": true,
    "arrays": true,
    "binary_content": false,
    "streaming": false
  },
  "field_mappings": [
    {
      "source_field": "title",
      "target_field": "title",
      "required": true
    },
    {
      "source_field": "content",
      "target_field": "body",
      "required": false
    },
    {
      "source_field": "tags",
      "target_field": "tags",
      "required": false,
      "transform": "array-or-split"
    },
    {
      "source_field": "created_at",
      "target_field": "last_updated",
      "required": false,
      "transform": "iso8601"
    },
    {
      "source_field": "author",
      "target_field": "owner",
      "required": false
    },
    {
      "source_field": "language",
      "target_field": "language",
      "required": false,
      "default": "en"
    }
  ],
  "transformation_rules": [
    {
      "rule": "strip_html",
      "description": "Remove HTML tags from text fields"
    },
    {
      "rule": "normalize_dates",
      "description": "Convert all dates to ISO 8601 format"
    },
    {
      "rule": "trim_whitespace",
      "description": "Remove leading/trailing whitespace from strings"
    },
    {
      "rule": "normalize_encoding",
      "description": "Convert all text to UTF-8"
    }
  ],
  "validation_on_import": {
    "required_fields": [
      "title",
      "industry",
      "department"
    ],
    "schema_ref": "document.schema.json",
    "fail_on_invalid": false,
    "quarantine_invalid": true
  },
  "import_notes": [
    "Root must be an object or array of objects",
    "Encoding must be UTF-8",
    "Nested arrays are flattened to strings"
  ],
  "error_handling": {
    "on_missing_required": "quarantine",
    "on_invalid_type": "coerce",
    "on_unknown_field": "ignore",
    "max_errors_before_abort": 100
  }
}
