{
  "schema_version": "1.0.0",
  "format_name": "Markdown",
  "format_id": "markdown",
  "mime_type": "text/markdown",
  "description": "Import specification for Markdown (.md) files. Frontmatter YAML is parsed as metadata.",
  "version": "1.0.0",
  "last_updated": "2026-07-13T00:00:00.000Z",
  "supported_features": {
    "nested_objects": true,
    "arrays": true,
    "binary_content": false,
    "streaming": false
  },
  "field_mappings": [
    {
      "source_field": "frontmatter.title",
      "target_field": "title",
      "required": true
    },
    {
      "source_field": "frontmatter.tags",
      "target_field": "tags",
      "required": false
    },
    {
      "source_field": "frontmatter.owner",
      "target_field": "owner",
      "required": false
    },
    {
      "source_field": "frontmatter.priority",
      "target_field": "priority",
      "required": false,
      "default": "medium"
    },
    {
      "source_field": "body",
      "target_field": "body",
      "required": true,
      "transform": "preserve-markdown"
    },
    {
      "source_field": "frontmatter.date",
      "target_field": "last_updated",
      "required": false,
      "transform": "iso8601"
    }
  ],
  "transformation_rules": [
    {
      "rule": "strip_html",
      "description": "Remove HTML tags from text fields"
    },
    {
      "rule": "normalize_dates",
      "description": "Convert all dates to ISO 8601 format"
    },
    {
      "rule": "trim_whitespace",
      "description": "Remove leading/trailing whitespace from strings"
    },
    {
      "rule": "normalize_encoding",
      "description": "Convert all text to UTF-8"
    }
  ],
  "validation_on_import": {
    "required_fields": [
      "title",
      "industry",
      "department"
    ],
    "schema_ref": "document.schema.json",
    "fail_on_invalid": false,
    "quarantine_invalid": true
  },
  "import_notes": [
    "Frontmatter must be valid YAML between --- delimiters",
    "Title falls back to first H1 heading if not in frontmatter",
    "Images are extracted to assets folder"
  ],
  "error_handling": {
    "on_missing_required": "quarantine",
    "on_invalid_type": "coerce",
    "on_unknown_field": "ignore",
    "max_errors_before_abort": 100
  }
}
