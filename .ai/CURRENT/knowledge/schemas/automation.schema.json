{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Automation Schema",
  "description": "Canonical schema for workflow automation specifications. Defines triggers, conditions, actions, and integration mappings.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "version",
    "language",
    "country",
    "industry",
    "department",
    "priority",
    "owner",
    "last_updated",
    "automation_type",
    "trigger",
    "actions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version (semver)",
      "default": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique document identifier (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "description": "Document title",
      "minLength": 1,
      "maxLength": 255
    },
    "version": {
      "type": "string",
      "description": "Document version (semver)",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "default": "1.0.0"
    },
    "language": {
      "type": "string",
      "description": "Document language (BCP-47)",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "default": "en",
      "examples": [
        "en",
        "en-US",
        "ar",
        "fr",
        "es"
      ]
    },
    "country": {
      "type": "string",
      "description": "Target country (ISO 3166-1 alpha-2)",
      "pattern": "^[A-Z]{2}$",
      "examples": [
        "US",
        "EG",
        "AE",
        "GB",
        "FR"
      ]
    },
    "industry": {
      "type": "string",
      "description": "Industry identifier",
      "enum": [
        "hotels",
        "restaurants",
        "medical-clinics",
        "real-estate",
        "travel-agencies"
      ]
    },
    "department": {
      "type": "string",
      "description": "Department identifier",
      "enum": [
        "company",
        "operations",
        "sales",
        "marketing",
        "support",
        "faq",
        "templates",
        "prompts",
        "policies",
        "playbooks",
        "training",
        "automation",
        "analytics"
      ]
    },
    "tags": {
      "type": "array",
      "description": "Classification and discovery tags",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "maxItems": 20
    },
    "priority": {
      "type": "string",
      "description": "Document priority level",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "owner": {
      "type": "string",
      "description": "Document owner (email or identifier)",
      "maxLength": 255
    },
    "last_updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update",
      "format": "date-time"
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256 checksum placeholder (format: sha256:hex)",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "automation_type": {
      "type": "string",
      "enum": [
        "trigger-action",
        "scheduled",
        "webhook",
        "event-driven",
        "conditional"
      ],
      "description": "Automation pattern type"
    },
    "trigger": {
      "type": "object",
      "required": [
        "type",
        "event"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "event",
            "schedule",
            "webhook",
            "manual",
            "condition"
          ]
        },
        "event": {
          "type": "string",
          "description": "Event name or cron expression"
        },
        "source": {
          "type": "string",
          "description": "System that emits the trigger"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string"
              },
              "operator": {
                "type": "string",
                "enum": [
                  "eq",
                  "neq",
                  "gt",
                  "lt",
                  "gte",
                  "lte",
                  "contains",
                  "in",
                  "not_in"
                ]
              },
              "value": {}
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "type",
          "target"
        ],
        "properties": {
          "action_id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "notify",
              "create",
              "update",
              "delete",
              "call-api",
              "run-prompt",
              "assign",
              "log"
            ]
          },
          "target": {
            "type": "string",
            "description": "System or entity the action targets"
          },
          "parameters": {
            "type": "object",
            "additionalProperties": true
          },
          "on_failure": {
            "type": "string",
            "enum": [
              "continue",
              "stop",
              "retry",
              "alert"
            ]
          }
        }
      }
    },
    "description": {
      "type": "string",
      "description": "Document description",
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "description": "Document lifecycle status",
      "enum": [
        "draft",
        "review",
        "approved",
        "published",
        "archived",
        "deprecated"
      ],
      "default": "draft"
    },
    "effective_date": {
      "type": "string",
      "description": "Date from which document takes effect",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "description": "Date on which document expires",
      "format": "date"
    },
    "review_date": {
      "type": "string",
      "description": "Scheduled review date",
      "format": "date"
    },
    "created_by": {
      "type": "string",
      "description": "Creator identifier",
      "maxLength": 255
    },
    "approved_by": {
      "type": "string",
      "description": "Approver identifier",
      "maxLength": 255
    },
    "source_url": {
      "type": "string",
      "description": "Source URL or reference",
      "format": "uri"
    },
    "attachments": {
      "type": "array",
      "description": "Associated file attachments",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "checksum": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "path"
        ]
      }
    },
    "external_id": {
      "type": "string",
      "description": "External system identifier for integration",
      "maxLength": 255
    },
    "locale_overrides": {
      "type": "object",
      "description": "Locale-specific field overrides",
      "additionalProperties": true
    },
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "rate_limit": {
      "type": "object",
      "properties": {
        "max_runs_per_hour": {
          "type": "integer",
          "minimum": 1
        },
        "cooldown_minutes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "error_handling": {
      "type": "object",
      "properties": {
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 3
        },
        "retry_delay_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "alert_on_failure": {
          "type": "boolean",
          "default": true
        },
        "fallback_action": {
          "type": "string"
        }
      }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "External systems this automation integrates with"
    }
  },
  "additionalProperties": false
}
