{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Playbook Schema",
  "description": "Canonical schema for an operational playbook. Defines step sequences, decision points, and escalation paths.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "version",
    "language",
    "country",
    "industry",
    "department",
    "priority",
    "owner",
    "last_updated",
    "trigger",
    "steps",
    "expected_duration_minutes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version (semver)",
      "default": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique document identifier (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "description": "Document title",
      "minLength": 1,
      "maxLength": 255
    },
    "version": {
      "type": "string",
      "description": "Document version (semver)",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "default": "1.0.0"
    },
    "language": {
      "type": "string",
      "description": "Document language (BCP-47)",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "default": "en",
      "examples": [
        "en",
        "en-US",
        "ar",
        "fr",
        "es"
      ]
    },
    "country": {
      "type": "string",
      "description": "Target country (ISO 3166-1 alpha-2)",
      "pattern": "^[A-Z]{2}$",
      "examples": [
        "US",
        "EG",
        "AE",
        "GB",
        "FR"
      ]
    },
    "industry": {
      "type": "string",
      "description": "Industry identifier",
      "enum": [
        "hotels",
        "restaurants",
        "medical-clinics",
        "real-estate",
        "travel-agencies"
      ]
    },
    "department": {
      "type": "string",
      "description": "Department identifier",
      "enum": [
        "company",
        "operations",
        "sales",
        "marketing",
        "support",
        "faq",
        "templates",
        "prompts",
        "policies",
        "playbooks",
        "training",
        "automation",
        "analytics"
      ]
    },
    "tags": {
      "type": "array",
      "description": "Classification and discovery tags",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "maxItems": 20
    },
    "priority": {
      "type": "string",
      "description": "Document priority level",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "owner": {
      "type": "string",
      "description": "Document owner (email or identifier)",
      "maxLength": 255
    },
    "last_updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update",
      "format": "date-time"
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256 checksum placeholder (format: sha256:hex)",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trigger": {
      "type": "string",
      "description": "Condition or event that initiates this playbook",
      "maxLength": 500
    },
    "steps": {
      "type": "array",
      "description": "Ordered list of playbook steps",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "title",
          "action"
        ],
        "properties": {
          "step_id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "maxLength": 200
          },
          "action": {
            "type": "string",
            "maxLength": 2000
          },
          "decision_point": {
            "type": "boolean",
            "default": false
          },
          "next_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "condition": {
                  "type": "string"
                },
                "next_step_id": {
                  "type": "string"
                }
              }
            }
          },
          "responsible_role": {
            "type": "string"
          },
          "time_limit_minutes": {
            "type": "integer",
            "minimum": 1
          },
          "tools_required": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "expected_duration_minutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Expected total duration to complete playbook"
    },
    "description": {
      "type": "string",
      "description": "Document description",
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "description": "Document lifecycle status",
      "enum": [
        "draft",
        "review",
        "approved",
        "published",
        "archived",
        "deprecated"
      ],
      "default": "draft"
    },
    "effective_date": {
      "type": "string",
      "description": "Date from which document takes effect",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "description": "Date on which document expires",
      "format": "date"
    },
    "review_date": {
      "type": "string",
      "description": "Scheduled review date",
      "format": "date"
    },
    "created_by": {
      "type": "string",
      "description": "Creator identifier",
      "maxLength": 255
    },
    "approved_by": {
      "type": "string",
      "description": "Approver identifier",
      "maxLength": 255
    },
    "source_url": {
      "type": "string",
      "description": "Source URL or reference",
      "format": "uri"
    },
    "attachments": {
      "type": "array",
      "description": "Associated file attachments",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "checksum": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "path"
        ]
      }
    },
    "external_id": {
      "type": "string",
      "description": "External system identifier for integration",
      "maxLength": 255
    },
    "locale_overrides": {
      "type": "object",
      "description": "Locale-specific field overrides",
      "additionalProperties": true
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "escalation_path": {
      "type": "string"
    },
    "related_playbooks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_cycle_days": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
