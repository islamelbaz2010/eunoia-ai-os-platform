{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prompt Schema",
  "description": "Canonical schema for an AI prompt definition. Captures system instructions, variables, and expected outputs.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "version",
    "language",
    "country",
    "industry",
    "department",
    "priority",
    "owner",
    "last_updated",
    "prompt_type",
    "prompt_body",
    "model_target",
    "variables"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version (semver)",
      "default": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique document identifier (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "description": "Document title",
      "minLength": 1,
      "maxLength": 255
    },
    "version": {
      "type": "string",
      "description": "Document version (semver)",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "default": "1.0.0"
    },
    "language": {
      "type": "string",
      "description": "Document language (BCP-47)",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "default": "en",
      "examples": [
        "en",
        "en-US",
        "ar",
        "fr",
        "es"
      ]
    },
    "country": {
      "type": "string",
      "description": "Target country (ISO 3166-1 alpha-2)",
      "pattern": "^[A-Z]{2}$",
      "examples": [
        "US",
        "EG",
        "AE",
        "GB",
        "FR"
      ]
    },
    "industry": {
      "type": "string",
      "description": "Industry identifier",
      "enum": [
        "hotels",
        "restaurants",
        "medical-clinics",
        "real-estate",
        "travel-agencies"
      ]
    },
    "department": {
      "type": "string",
      "description": "Department identifier",
      "enum": [
        "company",
        "operations",
        "sales",
        "marketing",
        "support",
        "faq",
        "templates",
        "prompts",
        "policies",
        "playbooks",
        "training",
        "automation",
        "analytics"
      ]
    },
    "tags": {
      "type": "array",
      "description": "Classification and discovery tags",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "maxItems": 20
    },
    "priority": {
      "type": "string",
      "description": "Document priority level",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "owner": {
      "type": "string",
      "description": "Document owner (email or identifier)",
      "maxLength": 255
    },
    "last_updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update",
      "format": "date-time"
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256 checksum placeholder (format: sha256:hex)",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "prompt_type": {
      "type": "string",
      "description": "Classification of prompt purpose",
      "enum": [
        "system",
        "user",
        "assistant",
        "chain",
        "retrieval",
        "function"
      ]
    },
    "prompt_body": {
      "type": "string",
      "description": "The prompt text with variable placeholders (use {{variable_name}} syntax)",
      "minLength": 10,
      "maxLength": 100000
    },
    "model_target": {
      "type": "string",
      "description": "Intended AI model (e.g., claude-sonnet-4-6, gemini-1.5-pro)",
      "examples": [
        "claude-sonnet-4-6",
        "claude-opus-4-8",
        "gemini-1.5-pro",
        "gpt-4o"
      ]
    },
    "variables": {
      "type": "array",
      "description": "Variable definitions for template substitution",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "string",
              "number",
              "boolean",
              "array",
              "object"
            ]
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          },
          "default": {},
          "examples": {
            "type": "array"
          }
        }
      }
    },
    "description": {
      "type": "string",
      "description": "Document description",
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "description": "Document lifecycle status",
      "enum": [
        "draft",
        "review",
        "approved",
        "published",
        "archived",
        "deprecated"
      ],
      "default": "draft"
    },
    "effective_date": {
      "type": "string",
      "description": "Date from which document takes effect",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "description": "Date on which document expires",
      "format": "date"
    },
    "review_date": {
      "type": "string",
      "description": "Scheduled review date",
      "format": "date"
    },
    "created_by": {
      "type": "string",
      "description": "Creator identifier",
      "maxLength": 255
    },
    "approved_by": {
      "type": "string",
      "description": "Approver identifier",
      "maxLength": 255
    },
    "source_url": {
      "type": "string",
      "description": "Source URL or reference",
      "format": "uri"
    },
    "attachments": {
      "type": "array",
      "description": "Associated file attachments",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "checksum": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "path"
        ]
      }
    },
    "external_id": {
      "type": "string",
      "description": "External system identifier for integration",
      "maxLength": 255
    },
    "locale_overrides": {
      "type": "object",
      "description": "Locale-specific field overrides",
      "additionalProperties": true
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    },
    "max_tokens": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200000
    },
    "output_format": {
      "type": "string",
      "enum": [
        "text",
        "json",
        "markdown",
        "code"
      ]
    },
    "chain_of_thought": {
      "type": "boolean",
      "default": false
    },
    "examples": {
      "type": "array",
      "description": "Few-shot examples for this prompt",
      "items": {
        "type": "object",
        "properties": {
          "input": {
            "type": "object"
          },
          "output": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "properties": {
        "max_input_tokens": {
          "type": "integer"
        },
        "forbidden_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_disclaimers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
