{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KPI Schema",
  "description": "Canonical schema for Key Performance Indicator definitions. Metric structure, targets, and reporting cadence only.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "version",
    "language",
    "country",
    "industry",
    "department",
    "priority",
    "owner",
    "last_updated",
    "metric_name",
    "metric_category",
    "formula",
    "unit",
    "measurement_frequency",
    "target"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version (semver)",
      "default": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique document identifier (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "description": "Document title",
      "minLength": 1,
      "maxLength": 255
    },
    "version": {
      "type": "string",
      "description": "Document version (semver)",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "default": "1.0.0"
    },
    "language": {
      "type": "string",
      "description": "Document language (BCP-47)",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "default": "en",
      "examples": [
        "en",
        "en-US",
        "ar",
        "fr",
        "es"
      ]
    },
    "country": {
      "type": "string",
      "description": "Target country (ISO 3166-1 alpha-2)",
      "pattern": "^[A-Z]{2}$",
      "examples": [
        "US",
        "EG",
        "AE",
        "GB",
        "FR"
      ]
    },
    "industry": {
      "type": "string",
      "description": "Industry identifier",
      "enum": [
        "hotels",
        "restaurants",
        "medical-clinics",
        "real-estate",
        "travel-agencies"
      ]
    },
    "department": {
      "type": "string",
      "description": "Department identifier",
      "enum": [
        "company",
        "operations",
        "sales",
        "marketing",
        "support",
        "faq",
        "templates",
        "prompts",
        "policies",
        "playbooks",
        "training",
        "automation",
        "analytics"
      ]
    },
    "tags": {
      "type": "array",
      "description": "Classification and discovery tags",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "maxItems": 20
    },
    "priority": {
      "type": "string",
      "description": "Document priority level",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "owner": {
      "type": "string",
      "description": "Document owner (email or identifier)",
      "maxLength": 255
    },
    "last_updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update",
      "format": "date-time"
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256 checksum placeholder (format: sha256:hex)",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "metric_name": {
      "type": "string",
      "description": "Official KPI name",
      "maxLength": 200
    },
    "metric_category": {
      "type": "string",
      "enum": [
        "financial",
        "operational",
        "customer",
        "growth",
        "quality",
        "compliance",
        "employee"
      ]
    },
    "formula": {
      "type": "string",
      "description": "Calculation formula or method description",
      "maxLength": 1000
    },
    "unit": {
      "type": "string",
      "description": "Unit of measurement",
      "examples": [
        "%",
        "USD",
        "count",
        "minutes",
        "days",
        "score"
      ]
    },
    "measurement_frequency": {
      "type": "string",
      "enum": [
        "real-time",
        "hourly",
        "daily",
        "weekly",
        "monthly",
        "quarterly",
        "annual"
      ]
    },
    "target": {
      "type": "object",
      "properties": {
        "value": {
          "type": "number"
        },
        "direction": {
          "type": "string",
          "enum": [
            "higher-is-better",
            "lower-is-better",
            "within-range"
          ]
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "baseline": {
          "type": "number"
        }
      },
      "required": [
        "value",
        "direction"
      ]
    },
    "description": {
      "type": "string",
      "description": "Document description",
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "description": "Document lifecycle status",
      "enum": [
        "draft",
        "review",
        "approved",
        "published",
        "archived",
        "deprecated"
      ],
      "default": "draft"
    },
    "effective_date": {
      "type": "string",
      "description": "Date from which document takes effect",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "description": "Date on which document expires",
      "format": "date"
    },
    "review_date": {
      "type": "string",
      "description": "Scheduled review date",
      "format": "date"
    },
    "created_by": {
      "type": "string",
      "description": "Creator identifier",
      "maxLength": 255
    },
    "approved_by": {
      "type": "string",
      "description": "Approver identifier",
      "maxLength": 255
    },
    "source_url": {
      "type": "string",
      "description": "Source URL or reference",
      "format": "uri"
    },
    "attachments": {
      "type": "array",
      "description": "Associated file attachments",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "checksum": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "path"
        ]
      }
    },
    "external_id": {
      "type": "string",
      "description": "External system identifier for integration",
      "maxLength": 255
    },
    "locale_overrides": {
      "type": "object",
      "description": "Locale-specific field overrides",
      "additionalProperties": true
    },
    "data_source": {
      "type": "string",
      "description": "System or source of metric data"
    },
    "alert_thresholds": {
      "type": "object",
      "properties": {
        "warning": {
          "type": "number"
        },
        "critical": {
          "type": "number"
        }
      }
    },
    "dashboard_ref": {
      "type": "string"
    },
    "related_kpis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
